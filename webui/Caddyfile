{
    auto_https off
}

:80 {
    root * /srv
    file_server
    try_files {path} /index.html

    handle_path /api/core/* {
        reverse_proxy core-engine:8001
    }

    handle_path /api/intel/* {
        reverse_proxy intelligence-api:8002
    }

    # Market routes keep their /api/market prefix on the backend
    handle /api/market/* {
        reverse_proxy core-engine:8001
    }

    # /api/symbols/* -> /symbols/* on the backend
    handle /api/symbols/* {
        uri strip_prefix /api
        reverse_proxy core-engine:8001
    }

    handle_path /ws {
        reverse_proxy core-engine:8001
    }

    encode gzip
    log {
        output stdout
    }
}
