# SystemOne Configuration
# Copy this file to .env and update values

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=systemone
DB_USER=postgres
DB_PASSWORD=change_this_password

# Redis
REDIS_URL=redis://redis:6379/0

# Authentication
JWT_SECRET=change_this_to_a_random_64_character_string
JWT_EXPIRATION_HOURS=24

# Single-user mode (recommended for personal deployments)
# When true, no login screen: the UI fetches a static token from the API and
# every request authenticates as SINGLE_USER_NAME. Anyone who can reach the
# app can use it — keep the instance private. Set to false for multi-user
# mode with the htpasswd login screen.
SINGLE_USER_MODE=true
SINGLE_USER_TOKEN=change_this_to_a_long_random_string
SINGLE_USER_NAME=owner

# Logging
LOG_LEVEL=INFO

# Optional: OpenClaw Integration
OPENCLAW_ENABLED=false
OPENCLAW_API_URL=http://openclaw:8080
OPENCLAW_API_KEY=

# Optional: NTFY Notifications
NTFY_ENABLED=false
NTFY_SERVER_URL=https://ping.otchere.com
NTFY_TOPIC=portfolio

# Optional: SMTP (via OpenClaw)
SMTP_ENABLED=false
